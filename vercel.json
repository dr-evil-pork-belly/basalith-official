{
  "redirects": [
    {
      "source":      "/:path*",
      "has":         [{ "type": "host", "value": "www.basalith.xyz" }],
      "destination": "https://basalith.xyz/:path*",
      "permanent":   true
    }
  ],
  "functions": {
    "app/api/archive/transcribe-voice/route.ts": {
      "maxDuration": 60
    },
    "app/api/archive/process-document/route.ts": {
      "maxDuration": 60
    },
    "app/api/archive/process-video/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/send-photos",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/weekly-prompt",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/story-prompt-monday",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/story-prompt-friday",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/gratitude-note",
      "schedule": "0 9 2 * *"
    },
    {
      "path": "/api/cron/memory-game-start",
      "schedule": "0 9 * * 3"
    },
    {
      "path": "/api/cron/memory-game-reminder",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/memory-game-summary",
      "schedule": "0 18 * * 5"
    }
  ]
}
